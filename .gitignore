# =============================================================================
# API AFIP - .gitignore
# =============================================================================

# Node.js
node_modules/
dist/
build/
*.log

# Environment (global)
.env
.env.local
.env.production

# Server-specific (sensitive)
server/.env
server/certs/
server/certs/*
!server/certs/.gitkeep

# Worker-specific
worker/.env
worker/.dev.vars

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Cloudflare
.wrangler/

# AFIP credentials (any folder)
*.crt
*.key
*.pem

# Testing
coverage/

# Misc
*.tgz