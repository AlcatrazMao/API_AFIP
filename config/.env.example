# =============================================================================
# API AFIP - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y completa los valores
# =============================================================================

# ==================== CONFIGURACIÓN GENERAL ====================

# Node.js environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ==================== SECURITY (OBLIGATORIO) ====================

# Clave API para clientes (se comunica con el Worker)
# Genera una clave segura: openssl rand -base64 32
PUBLIC_API_KEY=

# Clave interna para comunicación Worker → Server
# NO exponga esta clave al cliente
INTERNAL_API_KEY=

# ==================== BACKEND (SERVER LOCAL) ====================

# URL del servidor local a través de Cloudflare Tunnel
# Formato: https://tu-tunel.trycloudflare.com
AFIP_SERVICE_URL=

# Timeout para requests al servidor (en milisegundos)
AFIP_SERVICE_TIMEOUT=30000

# ==================== AFIP (FASE 3) ====================

# Credenciales AFIP - NO incluir en repositorio
# Estas variables se cargan desde archivos externos en producción

# AFIP_CUIT= # TU CUIT (sin guiones)
# AFIP_CERT_PATH= # Ruta al certificado .crt
# AFIP_KEY_PATH= # Ruta a la clave privada .key
# AFIP_ENV=homologacion  # o produccion

# ==================== CLOUDFLARE WORKER ====================

# Nombre del Worker
WORKER_NAME=afip-api

# ==================== RATE LIMITING ====================

# Requests por minuto por API key
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# INSTRUCCIONES DE SEGURIDAD
# =============================================================================
# 1. NUNCA commits este archivo al repositorio
# 2. Usa .gitignore para excluir .env
# 3. Para producción, usa Cloudflare Secrets:
#    wrangler secret put PUBLIC_API_KEY
#    wrangler secret put INTERNAL_API_KEY
# =============================================================================